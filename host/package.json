{
  "name": "ooda-desktop-host",
  "version": "1.9.1",
  "private": true,
  "description": "Optional desktop wrapper that feeds OODA real foreground-app + idle activity via the window.activity bridge.",
  "author": "OODA",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "get-windows": "^9.1.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ooda.desktophost",
    "productName": "OODA",
    "files": [
      "main.js",
      "preload.js",
      "hud.html",
      "hud-preload.js",
      "settings.html",
      "settings-preload.js",
      "build/icon.ico"
    ],
    "extraResources": [
      { "from": "../index.html", "to": "app-web/index.html" },
      { "from": "../manifest.json", "to": "app-web/manifest.json" },
      { "from": "../sw.js", "to": "app-web/sw.js" },
      { "from": "../icons", "to": "app-web/icons" }
    ],
    "asarUnpack": [
      "**/node_modules/get-windows/**"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
